rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_superAdmin/$(request.auth.uid));
    }
    function isContentManager() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_contentManager/$(request.auth.uid));
    }
    function isAdmin() {
      return isSuperAdmin() || isContentManager();
    }
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /roles_superAdmin/{userId} {
      allow get, list, create: if isSuperAdmin();
      allow update, delete: if isExistingAdmin();
    }
    match /roles_contentManager/{userId} {
      allow get, list, create: if isSuperAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /articles/{articleId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isExistingAdmin();
    }

    match /events/{eventId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isExistingAdmin();
    }

    match /publications/{publicationId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isExistingAdmin();
    }
    
    match /media/{mediaId} {
        allow get, list: if true;
        allow create: if isAdmin();
        allow update, delete: if isExistingAdmin();
    }

    match /contactMessages/{messageId} {
      allow get, list, update: if isAdmin();
      allow create: if true;
      allow delete: if isExistingAdmin();
    }
    
    match /singleContent/{docId} {
        allow get: if true;
        allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}